# ─────────────────────────────────────
# Supabase
# ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 타입 자동생성 시 사용 (Dashboard URL의 ref)
SUPABASE_PROJECT_REF=

# ─────────────────────────────────────
# Web Push (VAPID) — `pnpm dlx web-push generate-vapid-keys`로 생성
# ─────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dongtony1@gmail.com

# ─────────────────────────────────────
# Anthropic (음식 사진 캡션 + 안부 메시지 생성)
# ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────
# 알리고 SMS (부모님 발송)
# ─────────────────────────────────────
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=

# ─────────────────────────────────────
# Cron 인증 (Vercel Cron이 호출 시 검증)
# ─────────────────────────────────────
CRON_SECRET=
